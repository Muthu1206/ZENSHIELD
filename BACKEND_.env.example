/**
 * Backend Environment Variables
 * File: .env (create this in your backend root directory)
 * 
 * IMPORTANT: 
 * 1. Copy this file to .env
 * 2. Fill in your actual values
 * 3. NEVER commit .env to git
 * 4. Add .env to .gitignore
 */

# ============ SERVER ============
NODE_ENV=development
PORT=5000
HOST=localhost

# ============ DATABASE ============
# PostgreSQL Connection String
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/zenshield

# Database Pool Settings
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# ============ JWT AUTHENTICATION ============
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
REFRESH_TOKEN_SECRET=your-super-secret-refresh-key-minimum-32-characters-long

# Token Expiration Times
ACCESS_TOKEN_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=30d

# ============ TWILIO SMS GATEWAY ============
# Get these from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=AC0000000000000000000000000000
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ============ OTP SETTINGS ============
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
MAX_OTP_ATTEMPTS=5
MAX_OTP_REQUESTS_PER_HOUR=3

# ============ CORS & ORIGINS ============
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ============ LOGGING ============
LOG_LEVEL=info
LOG_FORMAT=combined

# ============ AWS (Optional) ============
# Use AWS S3 for storing evidence files
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=zenshield-evidence

# ============ EMAIL (Optional) ============
# For sending email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@zenshield.com

# ============ DEBUGGING ============
DEBUG=zenshield:*
VERBOSE=false